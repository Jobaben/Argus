{
  "name": "@argus/server",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "ARGUS_HOST=0.0.0.0 ARGUS_ALLOWED_HOSTS=10.59.1.53 node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "test:coverage": "tsx --test --experimental-test-coverage --test-coverage-lines=70 --test-coverage-functions=58 --test-coverage-branches=58 \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@hono/node-server": "^2.0.11",
    "chokidar": "^4.0.3",
    "hono": "^4.12.31",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/ws": "^8.5.13",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "tsx": "^4.23.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.65.0"
  }
}
